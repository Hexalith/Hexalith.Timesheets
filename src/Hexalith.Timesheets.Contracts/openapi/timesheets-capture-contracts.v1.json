{
  "openapi": "3.1.0",
  "info": {
    "title": "Hexalith Timesheets Capture Contracts",
    "version": "1.0",
    "summary": "Stable contract description for Timesheets time capture, Activity Type catalog, evidence reads, and metadata descriptors."
  },
  "x-hexalith-boundaries": {
    "serverDerivedContext": [
      "tenant",
      "user",
      "correlation",
      "authorization"
    ],
    "nonOwnedState": [
      "Party display and contact data",
      "Project or Work names, hierarchy, planning, or lifecycle state",
      "Tenant membership state",
      "finance-owned state"
    ],
    "notInCallerPayloads": [
      "messageId",
      "causationId",
      "sequence",
      "stream",
      "aggregate internals",
      "claims",
      "jwt",
      "token"
    ]
  },
  "x-hexalith-evidence-policy": {
    "retentionCategories": [
      {
        "name": "TimeEntryEvidence",
        "default": "RetainedByDefault",
        "guidance": "Time Entry evidence is retained by default."
      },
      {
        "name": "CommentText",
        "default": "LegalHoldRequired",
        "guidance": "Comment retention policy is unresolved."
      },
      {
        "name": "ExportRecord",
        "default": "TenantOverrideRequired",
        "guidance": "Export record retention requires tenant policy."
      },
      {
        "name": "MagicLinkConfirmationAuditMetadata",
        "default": "LegalHoldRequired",
        "guidance": "Confirmation audit metadata retention is unresolved."
      }
    ],
    "commentRules": [
      "Comments may contain sensitive information.",
      "Comments may be excluded by policy.",
      "Comment export is disabled until policy allows it.",
      "Comments are excluded from diagnostics."
    ],
    "launchReadinessGaps": [
      "Legal-hold policy is unresolved.",
      "Tenant-specific retention overrides are unresolved.",
      "Comment sensitivity policy is unresolved."
    ]
  },
  "components": {
    "schemas": {
      "RecordTimeEntry": {
        "type": "object",
        "required": [
          "timeEntryId",
          "target",
          "contributor",
          "activityTypeId",
          "serviceDate",
          "durationMinutes",
          "billableState",
          "contributorCategory"
        ],
        "properties": {
          "timeEntryId": { "$ref": "#/components/schemas/TimeEntryId" },
          "target": { "$ref": "#/components/schemas/TimeEntryTargetReference" },
          "contributor": { "$ref": "#/components/schemas/PartyReference" },
          "activityTypeId": { "$ref": "#/components/schemas/ActivityTypeId" },
          "serviceDate": { "type": "string", "format": "date" },
          "durationMinutes": { "type": "integer", "minimum": 1 },
          "billableState": { "$ref": "#/components/schemas/BillableState" },
          "contributorCategory": { "$ref": "#/components/schemas/ContributorCategory" },
          "aiMetrics": { "$ref": "#/components/schemas/AiEffortMetrics" },
          "comment": { "$ref": "#/components/schemas/TimeEntryComment" }
        }
      },
      "TimeEntryTargetReference": {
        "type": "object",
        "required": [ "targetKind", "targetId" ],
        "properties": {
          "targetKind": {
            "type": "string",
            "enum": [ "Unknown", "Project", "Work" ]
          },
          "targetId": { "type": "string", "minLength": 1 }
        }
      },
      "AiEffortMetrics": {
        "type": "object",
        "properties": {
          "availability": {
            "type": "string",
            "enum": [ "Unknown", "Unavailable", "ProviderReported", "Estimated" ]
          },
          "wallClockDurationMilliseconds": { "type": [ "integer", "null" ] },
          "modelRuntimeMilliseconds": { "type": [ "integer", "null" ] },
          "billableEffortMinutes": { "type": [ "integer", "null" ] },
          "providerInputTokenCount": { "type": [ "integer", "null" ] },
          "providerOutputTokenCount": { "type": [ "integer", "null" ] },
          "providerTotalTokenCount": { "type": [ "integer", "null" ] }
        }
      },
      "ActivityTypeCatalogCommand": {
        "type": "object",
        "description": "Create, rename, update metadata, deactivate, reactivate, or restrict Activity Types at tenant or project scope. Project-scoped commands carry only a stable Project reference."
      },
      "CreateProjectActivityType": {
        "type": "object",
        "required": [ "activityTypeId", "project", "label", "defaultBillableState" ],
        "properties": {
          "activityTypeId": { "$ref": "#/components/schemas/ActivityTypeId" },
          "project": { "$ref": "#/components/schemas/ProjectReference" },
          "label": { "type": "string", "minLength": 1 },
          "defaultBillableState": { "$ref": "#/components/schemas/BillableState" }
        }
      },
      "RenameProjectActivityType": {
        "type": "object",
        "required": [ "activityTypeId", "project", "label" ],
        "properties": {
          "activityTypeId": { "$ref": "#/components/schemas/ActivityTypeId" },
          "project": { "$ref": "#/components/schemas/ProjectReference" },
          "label": { "type": "string", "minLength": 1 }
        }
      },
      "UpdateProjectActivityTypeMetadata": {
        "type": "object",
        "required": [ "activityTypeId", "project", "defaultBillableState" ],
        "properties": {
          "activityTypeId": { "$ref": "#/components/schemas/ActivityTypeId" },
          "project": { "$ref": "#/components/schemas/ProjectReference" },
          "defaultBillableState": { "$ref": "#/components/schemas/BillableState" }
        }
      },
      "ConfigureProjectActivityTypeCatalogRestriction": {
        "type": "object",
        "required": [ "project", "isRestricted", "allowedTenantActivityTypeIds", "allowedProjectActivityTypeIds" ],
        "properties": {
          "project": { "$ref": "#/components/schemas/ProjectReference" },
          "isRestricted": { "type": "boolean" },
          "allowedTenantActivityTypeIds": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ActivityTypeId" }
          },
          "allowedProjectActivityTypeIds": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ActivityTypeId" }
          }
        }
      },
      "ActivityTypeCatalogReadModel": {
        "type": "object",
        "description": "Tenant Activity Type catalog read model with stable IDs, active/inactive text status, capture-selection availability metadata, and projection freshness.",
        "required": [ "items", "projectionFreshness" ],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ActivityTypeCatalogItem" }
          },
          "projectionFreshness": { "$ref": "#/components/schemas/ProjectionFreshnessMetadata" }
        }
      },
      "ActivityTypeCatalogItem": {
        "type": "object",
        "required": [
          "activityTypeId",
          "scope",
          "label",
          "isActive",
          "defaultBillableState",
          "activeState",
          "statusText",
          "isAvailableForCapture"
        ],
        "properties": {
          "activityTypeId": { "$ref": "#/components/schemas/ActivityTypeId" },
          "scope": { "$ref": "#/components/schemas/ActivityTypeScope" },
          "project": { "$ref": "#/components/schemas/ProjectReference" },
          "label": { "type": "string", "minLength": 1 },
          "isActive": { "type": "boolean" },
          "defaultBillableState": { "$ref": "#/components/schemas/BillableState" },
          "activeState": { "$ref": "#/components/schemas/ActivityTypeActiveState" },
          "statusText": { "type": "string", "enum": [ "Active", "Inactive" ] },
          "isAvailableForCapture": { "type": "boolean" }
        }
      },
      "TimeEntryEvidenceReadModel": {
        "type": "object",
        "description": "Evidence read model with stable references, approval/correction placeholders, optional AI metrics, optional policy-aware comment metadata, and projection freshness metadata."
      },
      "ProjectionFreshnessMetadata": {
        "type": "object",
        "properties": {
          "state": { "$ref": "#/components/schemas/ProjectionFreshnessState" },
          "cursor": { "type": [ "string", "null" ] },
          "asOfUtc": { "type": [ "string", "null" ], "format": "date-time" },
          "detail": { "type": [ "string", "null" ] }
        }
      },
      "TimeEntryComment": {
        "type": "object",
        "required": [ "text", "policy" ],
        "properties": {
          "text": { "type": "string", "minLength": 1, "maxLength": 4096 },
          "policy": { "$ref": "#/components/schemas/TimeEntryCommentPolicy" }
        }
      },
      "TimeEntryCommentPolicy": {
        "type": "object",
        "properties": {
          "internalDisplay": { "$ref": "#/components/schemas/TimesheetsCommentPolicyDecision" },
          "externalConfirmationDisplay": { "$ref": "#/components/schemas/TimesheetsCommentPolicyDecision" },
          "projectionInclusion": { "$ref": "#/components/schemas/TimesheetsCommentPolicyDecision" },
          "exportInclusion": { "$ref": "#/components/schemas/TimesheetsCommentPolicyDecision" },
          "supportDiagnostics": { "$ref": "#/components/schemas/TimesheetsCommentPolicyDecision" },
          "redactionRequirement": { "$ref": "#/components/schemas/TimesheetsCommentRedactionRequirement" },
          "retentionCategory": { "$ref": "#/components/schemas/TimesheetsEvidenceRetentionCategory" }
        }
      },
      "TimesheetsMetadataDescriptor": {
        "type": "object",
        "description": "Runtime-neutral metadata for generated command forms, projection views, fields, actions, and state badges."
      },
      "TimeEntryId": { "type": "string", "minLength": 1 },
      "ActivityTypeId": { "type": "string", "minLength": 1 },
      "PartyReference": { "type": "string", "minLength": 1 },
      "ProjectReference": {
        "type": "object",
        "required": [ "projectId" ],
        "properties": {
          "projectId": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "BillableState": {
        "type": "string",
        "enum": [ "Unknown", "NonBillable", "Billable" ]
      },
      "ActivityTypeScope": {
        "type": "string",
        "enum": [ "Unknown", "Tenant", "Project" ]
      },
      "ActivityTypeActiveState": {
        "type": "string",
        "enum": [ "Unknown", "Active", "Inactive" ]
      },
      "ProjectionFreshnessState": {
        "type": "string",
        "enum": [ "Unknown", "Fresh", "Rebuilding", "Stale", "Unavailable" ]
      },
      "ContributorCategory": {
        "type": "string",
        "enum": [ "Unknown", "Employee", "ExternalContributor", "AutomatedAgent" ]
      },
      "TimesheetsEvidenceRetentionCategory": {
        "type": "string",
        "enum": [ "Unknown", "TimeEntryEvidence", "CommentText", "ExportRecord", "MagicLinkConfirmationAuditMetadata" ]
      },
      "TimesheetsRetentionPosture": {
        "type": "string",
        "enum": [ "Unknown", "RetainedByDefault", "ExcludedByDefault", "RedactedByDefault", "LegalHoldRequired", "TenantOverrideRequired" ]
      },
      "TimesheetsCommentPolicyDecision": {
        "type": "string",
        "enum": [ "Unknown", "Allowed", "Excluded", "Redacted", "PolicyRequired" ]
      },
      "TimesheetsCommentRedactionRequirement": {
        "type": "string",
        "enum": [ "Unknown", "NotRequired", "RequiredBeforeExternalDisclosure", "RequiredBeforeExport" ]
      }
    }
  },
  "paths": {}
}
